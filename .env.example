# OpenClaw Easy 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ==================== Gateway 配置 ====================
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# ==================== AI 模型配置 ====================
# 主模型配置
API_KEY=your-api-key-here
BASE_URL=https://api.openai.com/v1
API_PROTOCOL=openai-completions
MODEL_ID=gpt-4o
IMAGE_MODEL_ID=gpt-4o
CONTEXT_WINDOW=200000
MAX_TOKENS=8192

# 备用模型配置（可选）
MODEL2_NAME=model2
MODEL2_API_KEY=
MODEL2_BASE_URL=
MODEL2_MODEL_ID=

# ==================== IM 渠道配置 ====================
# 飞书（可选）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BOT_NAME=OpenClaw Bot

# 钉钉（可选）
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=

# QQ机器人（可选）
QQBOT_APP_ID=
QQBOT_CLIENT_SECRET=

# 企业微信（可选）
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=

# ==================== 其他配置 ====================
OPENCLAW_PLUGINS_ENABLED=true
TZ=Asia/Shanghai

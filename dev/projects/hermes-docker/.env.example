# Hermes Agent 环境变量配置
# 复制为 .env 后填入实际值

# ==================== LLM 模型 ====================
# 默认模型（按需选择一个）
DEFAULT_MODEL=openrouter:auto

# OpenAI
OPENAI_API_KEY=

# OpenRouter（推荐，200+ 模型）
OPENROUTER_API_KEY=

# z.ai / GLM
ZAI_API_KEY=

# Kimi / Moonshot
MOONSHOT_API_KEY=

# MiniMax
MINIMAX_API_KEY=

# Hugging Face
HF_TOKEN=

# ==================== 消息平台 ====================
# Telegram
TELEGRAM_BOT_TOKEN=

# Discord
DISCORD_BOT_TOKEN=

# Slack
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ==================== 其他 ====================
TZ=Asia/Shanghai

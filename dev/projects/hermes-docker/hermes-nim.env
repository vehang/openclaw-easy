# Hermes NIM 版本环境配置
# 复制到 /opt/data/.env 使用

# === LLM - 智谱 GLM ===
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# === 飞书平台 ===
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# === 网易云信 (NIM) ===
# 多实例配置示例（JSON 格式）
NIM_INSTANCES=[{"appKey":"your_appkey","account":"your_account","nimToken":"your_token","p2p":true,"team":true,"qchat":true}]

# === 开放访问 ===
GATEWAY_ALLOW_ALL_USERS=true
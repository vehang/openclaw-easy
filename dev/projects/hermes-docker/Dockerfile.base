# ========================================
# Layer 1: Hermes Agent Base
# 系统依赖 + Node.js + Python + Playwright + uv + Claude Code
# ========================================
FROM debian:13.4

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright

# 使用国内镜像源加速
RUN sed -i 's|deb.debian.org|mirrors.aliyun.com|g; s|security.debian.org|mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list.d/debian.sources

# 系统依赖 - 分步安装避免 OOM
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential gcc libffi-dev procps git curl ca-certificates \
        python3 python3-venv python3-pip python3-dev \
        nodejs npm \
    && rm -rf /var/lib/apt/lists/*

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ripgrep ffmpeg xz-utils \
        tmux zsh fonts-powerline sudo wget \
    && rm -rf /var/lib/apt/lists/*

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        tree htop ncdu \
        bat eza fd-find fzf \
        jq yq httpie \
        gh \
    && rm -rf /var/lib/apt/lists/*

# fd 命令别名
RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd

# 安装 uv
RUN curl -LsSf https://astral.sh/uv/0.11.6/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

# 安装 Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# 预装 Playwright chromium (Chrome Headless Shell)
RUN npx playwright install --with-deps chromium --only-shell

WORKDIR /opt

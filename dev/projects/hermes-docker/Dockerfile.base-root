# ========================================
# Layer 1: Hermes Agent Base (Node 22 + Root)
# 系统依赖 + Node.js 22 + Python + Playwright + uv + Claude Code
# 全程 root，无用户切换
# ========================================
FROM debian:13.4

ENV PYTHONUNBUFFERED=1
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/hermes/.playwright

# ===== 国内镜像源 =====
RUN sed -i 's|deb.debian.org|mirrors.aliyun.com|g; s|security.debian.org|mirrors.aliyun.com/debian-security|g' /etc/apt/sources.list.d/debian.sources

# ===== 二进制下载加速（国内镜像）=====
ENV PUPPETEER_DOWNLOAD_HOST=https://cdn.npmmirror.com/binaries/chrome-for-testing
ENV PLAYWRIGHT_DOWNLOAD_HOST=https://cdn.npmmirror.com/binaries/playwright
ENV SASS_BINARY_SITE=https://cdn.npmmirror.com/binaries/node-sass
ENV ELECTRON_MIRROR=https://cdn.npmmirror.com/binaries/electron/
ENV CHROMIUM_DOWNLOAD_HOST=https://cdn.npmmirror.com/binaries/chromium-browser-snapshots
ENV CAMOUFOX_SKIP_DOWNLOAD=true

# ===== 系统依赖 - 分步安装避免 OOM =====

# 基础编译工具 + Python
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential gcc g++ make libffi-dev procps git curl ca-certificates \
        python3 python3-venv python3-pip python3-dev \
        xz-utils \
    && rm -rf /var/lib/apt/lists/*

# 媒体 + Shell 工具
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        ripgrep ffmpeg \
        tmux zsh fonts-powerline sudo wget \
    && rm -rf /var/lib/apt/lists/*

# 开发者工具
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        tree htop ncdu \
        bat eza fd-find fzf \
        jq yq httpie \
        gh \
    && rm -rf /var/lib/apt/lists/*

# native npm 模块编译依赖（puppeteer、camoufox 等）
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        libnss3 libatk-bridge2.0-0 libdrm2 libxkbcommon0 libgbm1 \
        libasound2 libxrandr2 libxcomposite1 libxdamage1 \
        libpango-1.0-0 libcairo2 libcups2 libxshmfence1 \
        libsecret-1-0 libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/fdfind /usr/local/bin/fd

# ===== Node.js 22 =====
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    rm -rf /var/lib/apt/lists/*

RUN echo "Node: $(node --version)" && echo "npm: $(npm --version)"

# ===== Python uv =====
RUN curl -LsSf https://astral.sh/uv/0.11.6/install.sh | sh
ENV PATH="/root/.local/bin:${PATH}"

# ===== JDK 8 (Eclipse Temurin) =====
RUN mkdir -p /opt/jdk && \
    curl -fsSL "https://github.com/adoptium/temurin8-binaries/releases/download/jdk8u482-b08/OpenJDK8U-jdk_x64_linux_hotspot_8u482b08.tar.gz" \
    | tar xz --strip-components=1 -C /opt/jdk

# ===== Maven 3.6.3 =====
RUN mkdir -p /opt/maven && \
    curl -fsSL "https://archive.apache.org/dist/maven/maven-3/3.6.3/binaries/apache-maven-3.6.3-bin.tar.gz" \
    | tar xz --strip-components=1 -C /opt/maven

# ===== Java 环境变量（全局）=====
RUN printf 'export JAVA_HOME=/opt/jdk\nexport PATH=$JAVA_HOME/bin:$PATH\nexport MAVEN_HOME=/opt/maven\nexport PATH=$MAVEN_HOME/bin:$PATH\n' > /etc/profile.d/java.sh

ENV JAVA_HOME=/opt/jdk
ENV MAVEN_HOME=/opt/maven
ENV PATH="/opt/jdk/bin:/opt/maven/bin:${PATH}"

# ===== Claude Code CLI（锁定版本）=====
RUN npm install -g @anthropic-ai/claude-code@2.1.112

# ===== Playwright Chromium（从官方源下载）=====
RUN PLAYWRIGHT_DOWNLOAD_HOST= npx playwright install --with-deps chromium --only-shell

# ===== npm 全局配置 =====
RUN npm config set registry https://registry.npmmirror.com

# ===== 验证 =====
RUN java -version && mvn -version && claude --version

# ===== 预创建目录 =====
RUN mkdir -p /opt/hermes /opt/data/{cron,sessions,logs,hooks,memories,skills,skins,plans,workspace,home}

WORKDIR /opt

# Git 相关
.git
.gitignore
.gitattributes

# Node.js 相关
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 开发时的 .next 构建文件（我们只要已构建的）
# 注意：不能忽略 .next，因为我们需要复制构建好的文件

# 环境变量和配置
.env*
!env.example

# 日志文件
logs
*.log

# 运行时数据
pids
*.pid
*.seed
*.pid.lock

# 缓存目录
.npm
.yarn/cache
.cache

# 临时文件
.tmp
.temp
temp/
tmp/

# 编辑器和IDE文件
.vscode
.idea
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# 测试覆盖率
coverage
*.lcov

# 文档和说明文件（保留部署文档）
README.md
CHANGELOG.md
LICENSE
*.md
!DOCKER_DEPLOYMENT.md

# Docker 相关（不需要这些文件在镜像内）
Dockerfile*
docker-compose*.yml
.dockerignore

# 脚本文件（构建时不需要）
scripts/

# 其他开发文件
.prettierrc
.eslintrc*
.editorconfig
jest.config.js
*.config.js
!next.config.js
!next.config.ts

# 源代码（我们只需要构建产物）
src/

# 其他构建输出
build/
dist/
out/ 